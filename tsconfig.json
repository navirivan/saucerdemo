{
	"compilerOptions": {
		"target": "es2016",
		"module": "commonjs",
		"esModuleInterop": true,
		"forceConsistentCasingInFileNames": true,
		"strict": true,
		"skipLibCheck": true,
		"paths": {
			"@fixtures/*": ["./src/fixtures/*"],
			"@pages/*": ["./src/pages/*"],
			"@api/*": ["./src/api/*"],
			"@data/*": ["./src/data/*"],
			"@helpers/*": ["./src/helpers/*"]
		}
	},
	"include": ["src"]
}
